						"rebuildDelay": 500,
						"dev": true,
						"cacheExternalArtifacts": false,
						"port": 0
					}
				},
				"test": {
					"builder": "@angular/build:unit-test"
				},
				"esbuild": {
					"builder": "@angular/build:application",
					"options": {
						"browser": "projects/task-form-mfe/src/main.ts",
						"tsConfig": "projects/task-form-mfe/tsconfig.app.json",
						"assets": [
							{
								"glob": "**/*",
								"input": "projects/task-form-mfe/public"
							}
						],
						"styles": [
							"projects/task-form-mfe/src/styles.css"
						],
						"polyfills": [
